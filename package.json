{
  "author": "niculistana",
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/pg-format": "^1.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "license": "ISC",
  "main": "index.js",
  "name": "transparency-cms",
  "scripts": {
    "build:all:production": "npm run clean && npm run prepare:build && npm run build:server:production && npm run build:client:production && npm run postbuild:production",
    "build:client:production": "NODE_ENV=production tsc -b && vite build --config vite.config.client.ts",
    "build:server:production": "NODE_ENV=production tsc -p tsconfig.server.json",
    "clean": "rm -fR dist && rm -fR build",
    "lint:client": "eslint .",
    "package:production": "npm run build:all:production && cp package.json dist && cp package-lock.json dist && zip -r dist-latest.zip dist && npm run clean",
    "postbuild:production": "mkdir -p dist && cp -R build dist",
    "prepare:build": "mkdir build && curl https://truststore.pki.rds.amazonaws.com/ap-southeast-1/ap-southeast-1-bundle.pem > build/cert.pem && cp -R sql build",
    "preview:production": "NODE_ENV=production node dist/build/server/index.js",
    "start:server": "NODE_ENV=development ./server/index.ts",
    "test": "tsx ./server/db.ts",
    "watch:client": "NODE_ENV=development vite",
    "watch:server": "NODE_ENV=development tsx watch ./server/index.ts"
  },
  "version": "1.0.0"
}
